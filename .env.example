# CEXpreTrader — конфигурация (order-flow momentum, PAPER, CEX-only).
# Всё read-only: реальные ордера не выставляются. Скопировать в .env и при желании
# переопределить. Значения ниже — дефолты (можно оставить файл почти пустым).

# ── Gate (CEX) ────────────────────────────────────────────────────────────
# Цены и лента сделок идут по публичному WebSocket (ccxt.pro) — ключи НЕ обязательны.
# Нужны лишь для точных taker/funding-комиссий аккаунта.
GATE_API_KEY=
GATE_API_SECRET=

# ── Order-flow momentum (paper-движок) ────────────────────────────────────
OFM_WINDOW_MS=5000          # окно расчёта OFI
OFM_OFI_PCT=0.8             # порог «сильного» OFI (перцентиль)
OFM_VOL_PCT=0.5             # порог «низкого» вола (перцентиль)
OFM_TARGET_BPS=20           # цель (мейкер-выход), bps
OFM_STOP_BPS=15             # стоп (тейкер-выход), bps
OFM_MAX_HOLD_MS=30000       # таймаут удержания
OFM_SIZE_USD=50
OFM_RING_SIZE=1500          # окно онлайн-калибровки порогов
OFM_MAKER_FEE=0.0002
OFM_TAKER_FEE=0.0005
# Реализм исполнения:
OFM_LATENCY_MS=20           # сигнал→филл (сеть Токио + матчинг Gate)
OFM_ENTRY_SLIP_BPS=2        # слиппедж входа тейкером
OFM_QUEUE_MULT=1            # мейкер-выход филлится, когда через цель прошёл объём ≥ mult×размер
OFM_PNL_WINDOW_MS=3600000   # окно трейлинг self-отбора символа по paper-PnL
OFM_PNL_WARMUP=8            # не бенчить символ, пока < N закрытий в окне

# ── Сканер кандидатов (REST по всем перпам Gate) ──────────────────────────
SCAN_INTERVAL_MS=3600000    # пересканировать раз в час
SCAN_MIN_VOL_USD=300000     # первичный фильтр: мин. 24ч объём
SCAN_MAX_SPREAD_BPS=30      # первичный фильтр: макс. спред (0.30%)
SCAN_DEEP_N=300             # глубокий скан markout/vol (кап-предохранитель)
SCAN_SELECT_K=6             # сколько реально торгуем (eligible)
SCAN_MIN_TPS=0.2            # мин. сделок/с (активность)
SCAN_MIN_MARKOUT_BPS=4      # мин. markout eligible (персистентность потока)
MOMENTUM_UNIVERSE_CAP=12    # WS-монитор = шорт-лист + тёплый буфер

# ── Веб / хранилище ───────────────────────────────────────────────────────
WEB_PORT=3001
DB_PATH=./data/cexpre.db
