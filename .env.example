# ── Alchemy (DEX-сторона) ─────────────────────────────────────────────────
# WSS — горячий путь (подписка на Swap). HTTP — только discovery (multicall).
ALCHEMY_WSS_ETH=wss://eth-mainnet.g.alchemy.com/v2/REPLACE_KEY
ALCHEMY_WSS_BSC=wss://bnb-mainnet.g.alchemy.com/v2/REPLACE_KEY
ALCHEMY_WSS_BASE=wss://base-mainnet.g.alchemy.com/v2/REPLACE_KEY
ALCHEMY_HTTP_ETH=https://eth-mainnet.g.alchemy.com/v2/REPLACE_KEY
ALCHEMY_HTTP_BSC=https://bnb-mainnet.g.alchemy.com/v2/REPLACE_KEY
ALCHEMY_HTTP_BASE=https://base-mainnet.g.alchemy.com/v2/REPLACE_KEY

# ── Gate (CEX-сторона) ────────────────────────────────────────────────────
# Цены берём по WebSocket (ccxt.pro watchOrderBook). На сервере в Токио Gate
# доступен напрямую — VPN/прокси не нужны.
# Ключи опциональны (нужны для точных taker/funding комиссий; для сканера не обязательны).
GATE_API_KEY=
GATE_API_SECRET=

# ── Параметры сканера ─────────────────────────────────────────────────────
OPEN_THRESHOLD_PCT=0.5
CLOSE_THRESHOLD_PCT=0.1
# Funding обновляем по REST раз в N мс (медленная величина).
FUNDING_REFRESH_MS=300000
MIN_LIQUIDITY_USD=20000
TRADE_SIZE_USD=100
# Мин. нотионал позиции (USD): меньше — не открываем (отсев пыли). 0 = без порога.
MIN_TRADE_SIZE_USD=5
MIN_PERP_VOLUME_USD=100000
ANCHOR_TOLERANCE_PCT=20
# Символы, исключаемые из универсума (высококонкурентные). Через запятую.
EXCLUDE_SYMBOLS=BTC,ETH
# Watchlist пересобирается автоматически при npm start, если старше N дней.
WATCHLIST_MAX_AGE_DAYS=7

# ── MM-сбор: лента сделок Gate ────────────────────────────────────────────
# Символы для записи ленты сделок (через запятую, базовые тикеры). Пусто →
# топ-N по ликвидности. Цель — активные символы с подходящим спредом.
TRADE_SYMBOLS=ICNT,COOKIE,UB,AIGENSYN,COAI,EVAA,SKYAI,AIA,ASTER,ARIA,LIGHT,ZAMA,AERO,OPEN,RE
# Если TRADE_SYMBOLS пусто — сколько символов брать (топ по ликвидности).
TRADE_SYMBOLS_LIMIT=15

# ── Веб / хранилище ───────────────────────────────────────────────────────
WEB_PORT=3001
DB_PATH=./data/cexpre.db
LOG_LEVEL=info
